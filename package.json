{
  "name": "email-unsubscribe",
  "version": "1.0.0",
  "description": "View unsubscribe links from recent Gmail messages",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": ["<rootDir>/cdk/"]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "googleapis": "^140.0.1",
    "memorystore": "^1.6.7",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "path-to-regexp": "^0.1.13",
    "picomatch": "^2.3.2",
    "brace-expansion": "^5.0.5"
  }
}
